<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="Background.Default" Color="#0D1117"/>

    <SolidColorBrush x:Key="Border.Default" Color="#30363D"/>

    <SolidColorBrush x:Key="Foreground.Primary" Color="#E6EDF3"/>
    <SolidColorBrush x:Key="Foreground.Secondary" Color="#7D8590"/>
    <SolidColorBrush x:Key="Foreground.Emphasis"  Color="#FFFFFF"/>
    <SolidColorBrush x:Key="Foreground.Placeholder" Color="#6E7681"/>

    <SolidColorBrush x:Key="Button.Default" Color="#21262D"/>
    <SolidColorBrush x:Key="Button.Hover" Color="#30363D"/>
    <SolidColorBrush x:Key="Button.Pressed" Color="#161B22"/>

    <SolidColorBrush x:Key="PrimaryButton.Default" Color="#238636"/>
    <SolidColorBrush x:Key="PrimaryButton.Hover" Color="#2EA043"/>
    <SolidColorBrush x:Key="PrimaryButton.Pressed" Color="#238636"/>
    <SolidColorBrush x:Key="PrimaryButton.Disabled" Color="#238636"/>

    <SolidColorBrush x:Key="DangerButton.Default" Color="#DA3633"/>
    <SolidColorBrush x:Key="DangerButton.Hover" Color="#F85149"/>
    <SolidColorBrush x:Key="DangerButton.Pressed" Color="#B62324"/>
    <SolidColorBrush x:Key="DangerButton.Disabled" Color="#DA3633"/>

    <Color x:Key="AccentRed">#D83434</Color>
    <Color x:Key="AccentYellow">#E6B325</Color>
    <Color x:Key="AccentGreen">#3CB371</Color>

    <LinearGradientBrush x:Key="StrengthGradient" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="{StaticResource AccentRed}" Offset="0.0"/>
        <GradientStop Color="{StaticResource AccentYellow}" Offset="0.5"/>
        <GradientStop Color="{StaticResource AccentGreen}" Offset="1.0"/>
    </LinearGradientBrush>

</ResourceDictionary>
