<Window x:Class="BenScr.PasswordGeneratorWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PasswordGeneratorWPF"
        mc:Ignorable="d"
        Title="Passwort-Generator"
        Height="550" Width="900"
        MinHeight="550" MinWidth="760"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="{StaticResource Background.Default}" Icon="/Views/icon.png"
        Foreground="{StaticResource Foreground.Primary}"
        FontFamily="Segoe UI">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Resources/Colors.xaml" />
                <ResourceDictionary Source="../Resources/Controls.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Passwort-Generator"
                   FontSize="21"
                   FontWeight="SemiBold"
                   Margin="0,0,0,12"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" MinWidth="270"/>
                <ColumnDefinition Width="3*" MinWidth="360"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                <GroupBox Header="Length">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Slider Grid.Row="0" Grid.Column="0"
                                x:Name="passwordLengthSlider"
                                Minimum="16" Maximum="64" Value="16" TickFrequency="1"
                                IsSnapToTickEnabled="True"
                                Margin="5,8,10,6"/>

                        <TextBox Grid.Row="0" Grid.Column="1"
                                 Style="{StaticResource DefaultTextBox}" 
                                 x:Name="passwordLengthTxt"
                                 Text="16"
                                 Width="60"
                                 HorizontalContentAlignment="Center"
                                 VerticalContentAlignment="Center"
                                 ToolTip="Password length"
                                 Margin="0,4,6,0"/>

                        <DockPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="5,6,0,0">
                            <TextBlock Text="Min: 16" DockPanel.Dock="Left" Margin="0,0,10,0"/>
                            <TextBlock Text="Max: 64" DockPanel.Dock="Right"/>
                        </DockPanel>
                    </Grid>
                </GroupBox>
                <GroupBox Header="Settings">
                    <UniformGrid Columns="2" Rows="2">
                        <CheckBox x:Name="lowerCaseCheckbox" Content="a–z (Lower-Case)" IsChecked="True"/>
                        <CheckBox x:Name="upperCaseCheckbox" Content="A–Z (Upper-Case)" IsChecked="True"/>
                        <CheckBox x:Name="digitCheckbox" Content="0–9 (Digits)" IsChecked="True"/>
                        <CheckBox x:Name="specialCharsCheckbox" Content="!@#… (Symbols)"/>
                    </UniformGrid>
                </GroupBox>

                <GroupBox Header="Characters" Margin="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Padding="5" Grid.Row="0" Grid.Column="0" Style="{StaticResource Caption}" Text="Include"/>
                        <TextBox Grid.Row="0" Grid.Column="1" x:Name="includeCharsTxt" Style="{StaticResource DefaultTextBox}" Height="24" Margin="5,0,0,0"/>

                        <TextBlock Padding="5" Grid.Row="1" Grid.Column="0" Style="{StaticResource Caption}" Text="Exclude"/>
                        <TextBox Grid.Row="1" Grid.Column="1" x:Name="excludeCharsTxt" Style="{StaticResource DefaultTextBox}" Height="24" Margin="5,0,0,0"/>
                    </Grid>
                </GroupBox>
            </StackPanel>
            <Grid Grid.Column="1" Margin="0,0,12,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <GroupBox Grid.Row="0" Header="Generated Password">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0" x:Name="passwordTxt"
                                 Style="{StaticResource DefaultTextBox}"
                                 MaxLength="1000"
                                 MinWidth="200"
                                 HorizontalScrollBarVisibility="Auto"
                                 FontFamily="Consolas" FontSize="16"
                                 VerticalContentAlignment="Center"
                                 ToolTip="Current Generated Password"
                                 Margin="0,0,6,0"/>

                        <Button Grid.Column="1" x:Name="copyButton" Content="Copy"/>
                        <Button Grid.Column="2" x:Name="addButton" Content="Save" ToolTip="Save password to history"/>
                    </Grid>
                </GroupBox>

                <GroupBox Grid.Row="1" Header="Strength" Margin="0,0,0,12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <ProgressBar Grid.Row="0"
                                     x:Name="strengthProgressbar"
                                     Minimum="0" Maximum="1" Value="0"
                                     ValueChanged="OnStrengthProgressbarValueChanged"
                                     Margin="0,0,0,8"/>

                        <TextBox Grid.Row="1"
                                 Style="{StaticResource DefaultTextBox}"
                                 x:Name="strengthInfoTextbox"
                                 IsReadOnly="True"
                                 VerticalScrollBarVisibility="Auto"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 Padding="6"/>
                    </Grid>
                </GroupBox>

                <GroupBox Grid.Row="2" Header="Password History" Margin="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Button Grid.Row="0"
                                    x:Name="saveCurrentToHistoryButton"
                                    Content="Save current password"
                                    ToolTip="Adds the generated password to the history"
                                    HorizontalAlignment="Left"
                                    Margin="0,0,0,8"/>

                    <ListBox Grid.Row="1"
                                     x:Name="passwordHistory"
                                     FontFamily="Consolas"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     MinHeight="190"/>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                        <Button x:Name="clearHistoryButton" Content="Clear History"/>
                        <Button x:Name="saveToFileButton" ToolTip="Saves the history into a .txt file" Content="Save To File"/>
                    </StackPanel>
                </Grid>
            </GroupBox>
        </Grid>
    </Grid>

    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,12,0,0">
            <Button x:Name="generateButton" Style="{StaticResource PrimaryButton}" Padding="15" Content="Generate" Margin="0,0,6,0"/>
            <Button x:Name="closeButton" Padding="15" Content="Close"/>
        </StackPanel>
    </Grid>
</Window>

